# Copy this file to .env and fill in your values (never commit .env)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard password
LUMINA_ADMIN_PASSWORD=change-me

# SMTP for email OTP (leave blank to use Ethereal test previews in console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Lumina Candles" <noreply@yourdomain.com>
